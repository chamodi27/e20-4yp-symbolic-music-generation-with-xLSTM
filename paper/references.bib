	author = {Wei, Lijun and Yu, Yuanyu and Qin, Yuping and Zhang, Shuang},
	month = aug,
	year = {2025},
	keywords = {music artificial intelligence, music education and learning, music generation, music rehabilitation and therapy},
	pages = {656},
}

