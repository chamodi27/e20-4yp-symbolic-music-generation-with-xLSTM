@inproceedings{solak_benchmarking_2024,
	title = {Benchmarking {Music} {Generation} {Models} and {Metrics} via {Human} {Preference} {Studies}},
	url = {https://openreview.net/forum?id=105yqGIpVW},
	abstract = {Recent advancements have brought generated music closer to human-created compositions, yet evaluating these models remains challenging. While human preference is the gold standard for assessing quality, translating these subjective judgments into objective metrics, particularly for text-audio alignment and music quality, has proven difficult. In this work, we generate 6k songs using 12 state-of-the-art models and conduct a survey of 15k pairwise audio comparisons with 2.5k human participants to evaluate the correlation between human preferences and widely used metrics. To the best of our knowledge, this work is the first to rank current state-of-the-art music generation models and metrics based on human preference. To further the field of subjective metric evaluation, we provide open access to our dataset of generated music and human evaluations.},
	language = {en},
	urldate = {2025-12-16},
	author = {Solak, Ahmet and Grötschla, Florian and Lanzendörfer, Luca A. and Wattenhofer, Roger},
	month = oct,
	year = {2024},
}

@article{bandara_implicit_nodate,
	title = {Implicit {Hierarchical} {Modeling} of {Long}-{Term} {Structure} in {Symbolic} {Music} {Generation} {Using} {xLSTM}},
	abstract = {Deep learning has revolutionized symbolic music generation, yet achieving long-term structural coherence remains a persistent challenge, with generated pieces often lacking thematic development and sectional contrast. Current approaches present a trade-off: implicit architectures, such as standard RNNs and Transformers, excel at local continuation but struggle with global form, while explicitly hierarchical models achieve structural consistency but depend on rigid, pre-defined segmentation that restricts generalization. To address this limitation, this research investigates the Extended Long Short-Term Memory (xLSTM) architecture as a solution for implicit multi-timescale modeling. We hypothesize that xLSTM’s novel exponential gating and matrix memory mechanisms allow hierarchical dependencies to emerge organically, enabling the capture of both short-term dynamics and long-term structure without manual segmentation. This study implements an xLSTM-based symbolic generation model and benchmarks it against established baselines, including Music Transformer, MusicVAE, and Museformer. The models are assessed using a comprehensive evaluation strategy incorporating structure-aware metrics, such as motif recurrence and segmentation similarity, alongside human listening tests. Ultimately, this work aims to demonstrate xLSTM’s potential to bridge the gap between architectural flexibility and the control required for coherent long-form musical composition.},
	language = {en},
	author = {Bandara, Haritha and Senanayake, Yohan and Senaratne, Chamodi and Nawinne, Isuru},
}

